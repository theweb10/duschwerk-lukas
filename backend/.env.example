# Server
PORT=3001
NODE_ENV=development

# Email (Nodemailer)
# Für Tests: Mailtrap https://mailtrap.io
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_mailtrap_user
EMAIL_PASS=your_mailtrap_password
EMAIL_FROM="Duschwerk Bayern <noreply@duschwerk-bayern.de>"
EMAIL_TO=info@duschwerk-bayern.de

# CRM Integration (einen Provider wählen)
# CRM_PROVIDER: hubspot | zoho | webhook | none
CRM_PROVIDER=none

# HubSpot (wenn CRM_PROVIDER=hubspot)
HUBSPOT_API_KEY=your_hubspot_private_app_token

# Zoho CRM (wenn CRM_PROVIDER=zoho)
ZOHO_ACCESS_TOKEN=your_zoho_access_token
ZOHO_API_DOMAIN=https://www.zohoapis.eu

# Webhook / Zapier (wenn CRM_PROVIDER=webhook)
# Jede Kontaktanfrage wird als JSON-POST an diese URL gesendet
CRM_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_HOOK_ID/

# CORS – erlaubte Frontend-Origins, kommagetrennt
CORS_ORIGIN=http://localhost:5173
